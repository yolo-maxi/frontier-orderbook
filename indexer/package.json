{
  "name": "@frontier/indexer",
  "version": "0.1.0",
  "private": true,
  "description": "Indexer + REST/WebSocket API for the Frontier on-chain orderbook",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "frontier-indexer": "./bin/cli.mjs"
  },
  "exports": {
    ".": "./src/server.ts",
    "./client": "./src/client.ts",
    "./queries": "./src/queries.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "index": "tsx src/indexer/run.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/websocket": "^11.0.2",
    "viem": "^2.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
